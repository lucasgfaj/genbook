<div class="container mt-5">
    <h2 class="fw-bold mb-4">Adicionar Novo Autor</h2>

    <form id="addAuthorForm" method="POST" action="/authors">

        <div class="mb-3 position-relative">
            <label for="authorFullName" class="form-label">Nome Completo</label>
            <input
                type="text"
                class="form-control"
                id="authorFullName"
                name="author[full_name]"
                placeholder="Nome completo do autor"
                autocomplete="off"
                required
                value="<?= htmlspecialchars($author->full_name ?? '') ?>"
                aria-autocomplete="list"
                aria-controls="authorSuggestions"
                aria-haspopup="true"
                aria-expanded="false" />

            <ul id="authorSuggestions"
                class="list-group position-absolute w-100 shadow-sm"
                style="z-index: 1050; max-height: 250px; overflow-y: auto; top: 100%; left: 0; margin-top: 0.25rem; border-radius: 0 0 0.25rem 0.25rem;">
            </ul>
        </div>


        <div class="mb-3">
            <label for="authorNationality" class="form-label">Nacionalidade</label>
            <input
                type="text"
                class="form-control"
                id="authorNationality"
                name="author[nationality]"
                placeholder="Ex: Brasileiro"
                required
                value="<?= htmlspecialchars($author->nationality ?? '') ?>">
        </div>

        <div class="mb-3">
            <label for="authorBirthDate" class="form-label">Data de Nascimento</label>
            <input
                type="date"
                class="form-control"
                id="authorBirthDate"
                name="author[birth_date]"
                required
                value="<?= htmlspecialchars($author->birth_date ?? '') ?>">
        </div>

        <div class="mb-3">
            <label for="authorBio" class="form-label">Biografia</label>
            <textarea
                class="form-control"
                id="authorBio"
                name="author[bio]"
                rows="4"
                placeholder="Breve biografia do autor"
                required><?= htmlspecialchars($author->bio ?? '') ?></textarea>
        </div>

        <a href="/authors" class="btn btn-secondary me-2">Cancelar</a>
        <button type="submit" class="btn btn-primary">Adicionar Autor</button>
    </form>
</div>