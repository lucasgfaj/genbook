<form action="<?= route('authors.update', ['id' => $author->id]) ?>" method="POST">
    <input type="hidden" name="_method" value="PUT">

    <div class="row g-3">

        <div class="col-md-6">
            <label class="form-label">Nome Completo</label>
            <input type="text" name="author[full_name]" class="form-control"
                value="<?= htmlspecialchars($author->full_name) ?>" required>
        </div>

        <div class="col-md-6">
            <label class="form-label">Nacionalidade</label>
            <input type="text" name="author[nationality]" class="form-control"
                value="<?= htmlspecialchars($author->nationality) ?>">
        </div>

        <div class="col-md-6">
            <label class="form-label">Data de Nascimento</label>
            <input type="date" name="author[birth_date]" class="form-control"
                value="<?= htmlspecialchars(date('Y-m-d', strtotime($author->birth_date))) ?>">
        </div>

        <div class="col-md-6">
            <label for="is_active" class="form-label">Status</label>
            <input id="is_active" type="text" class="form-control"
                value="<?= $author->is_active ? 'Ativo' : 'Inativo' ?>" disabled>
        </div>

        <div class="col-md-12">
            <label class="form-label">Biografia</label>
            <textarea name="author[bio]" class="form-control" rows="5"><?= htmlspecialchars($author->bio) ?></textarea>
        </div>

    </div>

    <div class="d-flex justify-content-end mt-4 gap-2">
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-circle"></i> Salvar Alterações
        </button>
    </div>
</form>
