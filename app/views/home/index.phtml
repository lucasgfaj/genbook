 <div class="container py-4">
    <h2 class="mb-4">Dashboard</h2>

    <!-- Cards Resumo -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-3 mb-4">
      <!-- Livros Disponíveis -->
      <div class="col">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex align-items-center">
            <i class="bi bi-book fs-1 text-primary me-3"></i>
            <div>
              <h6 class="text-muted mb-0">Livros Disponíveis</h6>
              <h3 class="mb-0">230</h3>
            </div>
          </div>
        </div>
      </div>

      <!-- Usuários Ativos -->
      <div class="col">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex align-items-center">
            <i class="bi bi-people-fill fs-1 text-success me-3"></i>
            <div>
              <h6 class="text-muted mb-0">Usuários Ativos</h6>
              <h3 class="mb-0">125</h3>
            </div>
          </div>
        </div>
      </div>

      <!-- Empréstimos -->
      <div class="col">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex align-items-center">
            <i class="bi bi-journal-arrow-down fs-1 text-warning me-3"></i>
            <div>
              <h6 class="text-muted mb-0">Empréstimos</h6>
              <h3 class="mb-0">87</h3>
            </div>
          </div>
        </div>
      </div>

      <!-- Atrasos -->
      <div class="col">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-1 text-danger me-3"></i>
            <div>
              <h6 class="text-muted mb-0">Atrasos</h6>
              <h3 class="mb-0">5</h3>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Conteúdo Principal -->
    <div class="row g-3">
      <!-- Tabela de Empréstimos -->
      <div class="col-12 col-lg-8">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Empréstimos Recentes</h5>
            <div class="table-responsive">
              <table class="table table-hover align-middle text-nowrap">
                <thead class="table-light">
                  <tr>
                    <th>Aluno</th>
                    <th>Item/Livro</th>
                    <th>Data</th>
                    <th>Devolução</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Lucas Ferreira</td>
                    <td>HTML e CSS - Jon Duckett</td>
                    <td>20/05/2025</td>
                    <td>27/05/2025</td>
                    <td><span class="badge bg-success">Ativo</span></td>
                  </tr>
                  <tr>
                    <td>Maria Santos</td>
                    <td>JavaScript Avançado</td>
                    <td>15/05/2025</td>
                    <td>22/05/2025</td>
                    <td><span class="badge bg-danger">Atrasado</span></td>
                  </tr>
                  <tr>
                    <td>Pedro Oliveira</td>
                    <td>Python para Iniciantes</td>
                    <td>10/05/2025</td>
                    <td>17/05/2025</td>
                    <td><span class="badge bg-secondary">Devolvido</span></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Painel de Alertas -->
      <div class="col-12 col-lg-4">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Alertas</h5>
            <div class="alert alert-danger d-flex align-items-center" role="alert">
              <i class="bi bi-exclamation-circle-fill me-2"></i>
              5 livros estão com devolução atrasada!
            </div>
            <div class="alert alert-warning d-flex align-items-center" role="alert">
              <i class="bi bi-clock-history me-2"></i>
              2 empréstimos vencem amanhã.
            </div>
            <div class="alert alert-info d-flex align-items-center" role="alert">
              <i class="bi bi-info-circle-fill me-2"></i>
              Novos livros foram adicionados ao acervo.
            </div>
          </div>
        </div>
      </div>
    </div>
