<div class="container py-4">
  <h2 class="mb-4">Área Administrativa</h2>

  <!-- Configuração de Multa -->
  <div class="card mb-4 shadow-sm">
    <div class="card-body">
      <h5 class="card-title">Configurações de Multa</h5>
      <div class="row g-3 align-items-center">
        <div class="col-md-6">
          <label for="valorMultaPadrao" class="form-label">Valor padrão da multa (R$)</label>
          <input type="number" step="0.01" id="valorMultaPadrao" class="form-control" value="2.50">
        </div>
        <div class="col-md-6 text-end">
          <button class="btn btn-success mt-4" id="btnAtualizarMulta">
            <i class="bi bi-check-circle me-1"></i> Atualizar Multa
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Gerenciar Categorias -->
  <div class="card mb-4 shadow-sm">
    <div class="card-body">
      <h5 class="card-title">Gerenciar Categorias</h5>
      <div class="row g-3 mb-3">
        <div class="col-md-8">
          <input type="text" id="novaCategoria" class="form-control" placeholder="Nova categoria">
        </div>
        <div class="col-md-4 text-end">
          <button class="btn btn-primary w-100" onclick="adicionarCategoria()">
            <i class="bi bi-plus-circle me-1"></i> Adicionar Categoria
          </button>
        </div>
      </div>
      <ul class="list-group" id="listaCategorias">
        <!-- Itens gerados dinamicamente -->
      </ul>
    </div>
  </div>

  <!-- Definir validade para item -->
  <div class="card shadow-sm">
    <div class="card-body">
      <h5 class="card-title">Definir Data de Validade para Livro/Item</h5>
      <div class="row g-3">
        <div class="col-md-6">
          <label for="nomeItem" class="form-label">Livro/Item</label>
          <input type="text" id="nomeItem" class="form-control" placeholder="Ex: JavaScript Avançado">
        </div>
        <div class="col-md-4">
          <label for="dataValidade" class="form-label">Data de Validade</label>
          <input type="date" id="dataValidade" class="form-control">
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-info w-100" onclick="salvarValidade()">
            <i class="bi bi-calendar-check me-1"></i> Salvar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Editar Categoria -->
<div class="modal fade" id="modalEditarCategoria" tabindex="-1" aria-labelledby="editarCategoriaLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Editar Categoria</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        <input type="text" id="editarInputCategoria" class="form-control">
        <input type="hidden" id="categoriaIndex">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" onclick="salvarEdicaoCategoria()">Salvar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Confirmar Exclusão -->
<div class="modal fade" id="modalExcluirCategoria" tabindex="-1" aria-labelledby="excluirCategoriaLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Confirmar Exclusão</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Tem certeza que deseja excluir a categoria <strong id="nomeCategoriaExcluir"></strong>?
        <input type="hidden" id="categoriaExcluirIndex">
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button class="btn btn-danger" onclick="confirmarExclusao()">Excluir</button>
      </div>
    </div>
  </div>
</div>
