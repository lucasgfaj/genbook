
<div class="container mt-5">
  <h2 class="mb-4">Configurações</h2>

  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title">Notificações</h5>
      <p class="card-text text-muted">Configure como e quando você deseja receber notificações</p>

      <div class="d-flex justify-content-between align-items-center mb-2">
        <span>Notificar empréstimos atrasados</span>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch" checked>
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center mb-2">
        <span>Notificar materiais a expirar</span>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch" checked>
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Notificar estoque baixo</span>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch" checked>
        </div>
      </div>

      <p class="mb-2">Testar notificações</p>
      <div>
        <button class="btn btn-outline-secondary btn-sm me-2">Testar atraso</button>
        <button class="btn btn-outline-secondary btn-sm me-2">Testar expiração</button>
        <button class="btn btn-outline-secondary btn-sm">Testar estoque baixo</button>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h5 class="card-title">Preferências do sistema</h5>
      <p class="card-text text-muted">Personalize a aparência e comportamento do sistema</p>

      <div class="d-flex justify-content-between align-items-center mb-2">
        <span>Logout automático após 30 minutos</span>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch">
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center">
        <span>Receber relatórios por email</span>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch" checked>
        </div>
      </div>
    </div>
  </div>
</div>

