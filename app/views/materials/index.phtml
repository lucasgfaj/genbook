<!-- Modal para adicionar material -->
<div class="modal fade" id="addMaterialModal" tabindex="-1" aria-labelledby="addMaterialModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg"> <!-- Alterado para modal-lg -->
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="addMaterialModalLabel">Adicionar Novo Material</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>

      <div class="modal-body">
        <form>
          <div class="row g-3"> <!-- Começo da grid responsiva -->

            <div class="col-md-6">
              <label for="materialName" class="form-label">Nome</label>
              <input type="text" class="form-control" id="materialName" placeholder="Nome do material">
            </div>

            <div class="col-md-6">
              <label for="materialType" class="form-label">Tipo</label>
              <input type="text" class="form-control" id="materialType" placeholder="Tipo de material">
            </div>

            <div class="col-12">
              <label for="materialDescription" class="form-label">Descrição</label>
              <textarea class="form-control" id="materialDescription" rows="3" placeholder="Descrição detalhada"></textarea>
            </div>

            <div class="col-md-6">
              <label for="materialBrand" class="form-label">Marca</label>
              <input type="text" class="form-control" id="materialBrand" placeholder="Marca">
            </div>

            <div class="col-md-6">
              <label for="materialModel" class="form-label">Modelo</label>
              <input type="text" class="form-control" id="materialModel" placeholder="Modelo">
            </div>

            <div class="col-md-6">
              <label for="materialSerial" class="form-label">Número de Série</label>
              <input type="text" class="form-control" id="materialSerial" placeholder="Número de série">
            </div>

            <div class="col-md-3">
              <label for="materialQuantity" class="form-label">Quantidade</label>
              <input type="number" class="form-control" id="materialQuantity" value="1" min="1">
            </div>

            <div class="col-md-3">
              <label for="materialUnit" class="form-label">Unidade</label>
              <input type="text" class="form-control" id="materialUnit" placeholder="unidade, caixa...">
            </div>

            <div class="col-md-6">
              <label for="materialLocation" class="form-label">Localização</label>
              <input type="text" class="form-control" id="materialLocation" placeholder="Ex: Laboratório, Almoxarifado...">
            </div>

          </div> <!-- fim .row -->
        </form>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Adicionar Material</button>
      </div>

    </div>
  </div>
</div>
