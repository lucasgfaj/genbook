<div class="modal fade" id="addMaterialModal" tabindex="-1" aria-labelledby="addMaterialModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="addMaterialModalLabel">Adicionar Novo Material</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>

      <div class="modal-body">
        <form>

          <div class="mb-3">
            <label for="materialName" class="form-label">Nome</label>
            <input type="text" class="form-control" id="materialName" placeholder="Nome do material">
          </div>

          <div class="mb-3">
            <label for="materialType" class="form-label">Tipo</label>
            <input type="text" class="form-control" id="materialType" placeholder="Tipo do material">
          </div>

          <div class="mb-3">
            <label for="materialCategory" class="form-label">Categoria</label>
            <input type="text" class="form-control" id="materialCategory" placeholder="Categoria do material">
          </div>

          <div class="mb-3">
            <label for="materialValidity" class="form-label">Data de Validade</label>
            <input type="date" class="form-control" id="materialValidity" placeholder="dd/mm/aaaa">
            <small class="form-text text-muted">Opcional - para materiais com prazo de validade</small>
          </div>

          <div class="mb-3">
            <label for="materialQuantity" class="form-label">Quantidade</label>
            <input type="number" class="form-control" id="materialQuantity" value="1" min="1">
          </div>

          <div class="mb-3">
            <label for="materialDescription" class="form-label">Descrição</label>
            <textarea class="form-control" id="materialDescription" rows="3"
              placeholder="Descreva o material (opcional)"></textarea>
            <small class="form-text text-muted">Opcional - adicione detalhes sobre o material</small>
          </div>

          <div class="mb-3">
            <label for="materialImage" class="form-label">Imagem do Material</label>
            <input type="file" class="form-control" id="materialImage" accept="image/*">
          </div>

        </form>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Adicionar Material</button>
      </div>

    </div>
  </div>
</div>