<div class="container my-5">
  <h2 class="mb-4 text-primary fw-bold">Painel de Relatórios</h2>

  <!-- Filtros -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <form class="row g-3 align-items-end">
        <div class="col-md-5">
          <label for="tipo" class="form-label fw-semibold">Tipo de Relatório</label>
          <select class="form-select" id="tipo">
            <option selected>Selecionar...</option>
            <option>Usuários</option>
            <option>Livros</option>
            <option>Empréstimos</option>
          </select>
        </div>
        <div class="col-md-4">
          <label for="status" class="form-label fw-semibold">Status</label>
          <select class="form-select" id="status">
            <option selected>Todos</option>
            <option>Ativo</option>
            <option>Inativo</option>
          </select>
        </div>
        <div class="col-md-3">
          <button type="button" class="btn btn-primary w-100" onclick="gerarRelatorio()">
            <i class="bi bi-bar-chart"></i> Gerar
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Resultado + Exportação -->
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold">Resumo do Relatório</h5>
        <div>
          <button class="btn btn-outline-danger me-2" onclick="exportarPDF()">
            <i class="bi bi-filetype-pdf"></i> PDF
          </button>
          <button class="btn btn-outline-success" onclick="exportarExcel()">
            <i class="bi bi-filetype-xls"></i> Excel
          </button>
        </div>
      </div>

      <div id="resultadoRelatorio">
        <p class="text-muted">Gere um relatório para visualizar os dados.</p>
      </div>
    </div>
  </div>
</div>